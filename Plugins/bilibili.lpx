#!name=哔哩哔哩
#!desc=没有广告的哔哩哔哩更值得干杯。
#!author=RuCu6[https://github.com/RuCu6], kokoryh[https://github.com/kokoryh], 可莉🅥[https://gitlab.com/lodepuly/vpn_tool], zwjtano[https://github.com/zwjtano]
#!icon=https://raw.githubusercontent.com/zwjtano/icons/main/icons/bilibili.png
#!date=2026-07-04 02:10
#!loon_version=3.4.0(962)

[Argument]
displayUpList=select, "auto", "show", "hide", tag=显示 动态「最常访问」, desc=- auto: 仅当列表中存在直播状态时显示\n- show: 始终显示\n- hide: 始终隐藏
customizeDynamicPage=switch, true, false, tag=精简「动态页」, desc=- true: 开启\n- false: 关闭
customizeHomeTabs=switch, true, false, tag=自定义「首页顶部标签」, desc=- true: 按下方列表保留频道\n- false: 不处理顶部频道
homeTopTabs=input, "推荐,热门,影视,动画,足球季", tag=首页顶部标签, desc=用逗号分隔频道名，例如：推荐,热门,影视,动画,足球季,番剧
hideHomeTopGameCenter=switch, true, false, tag=隐藏首页「游戏中心」, desc=- true: 开启\n- false: 关闭
hideHomeBottomPublish=switch, true, false, tag=隐藏底栏「发布」, desc=- true: 开启\n- false: 关闭
hideHomeBottomMall=switch, true, false, tag=隐藏底栏「会员购」, desc=- true: 开启\n- false: 关闭
customizePgcPage=switch, true, false, tag=精简「观影页」, desc=- true: 开启\n- false: 关闭
customizeMinePage=switch, true, false, tag=精简「我的页面」, desc=- true: 开启\n- false: 关闭
customizeHomeFeed=switch, true, false, tag=过滤「首页推荐流」, desc=- true: 开启\n- false: 关闭
filterVerticalVideo=switch, true, false, tag=过滤「竖屏视频」, desc=- true: 开启\n- false: 关闭
filterHotSearch=switch, true, false, tag=过滤「热搜/热门话题」, desc=- true: 开启\n- false: 关闭
filterSearchSuggest=switch, true, false, tag=过滤「搜索推荐」, desc=- true: 开启\n- false: 关闭
filterDefaultSearchWord=switch, true, false, tag=屏蔽「默认搜索框关键词」, desc=- true: 开启\n- false: 关闭
optimizeRequest=switch, true, false, tag=过滤「视频内」插播广告, desc=自动跳过视频内广告\n- true: 开启\n- false: 关闭
purifyComment=switch, true, false, tag=过滤「评论区」置顶广告, desc=-true: 开启\n- false: 关闭
sponsorBlock=switch, true, false, tag=空降助手

[Rule]
# 空降助手
DOMAIN, bsbsb.top, PROXY
# 禁用STUN & P2P
AND, ((DOMAIN-SUFFIX, chat.bilibili.com), (OR, ((DOMAIN-KEYWORD, stun), (DOMAIN-KEYWORD, tracker), (DOMAIN-KEYWORD, p2p)))), REJECT
# 垃圾CDN
#AND, ((NOT, ((DEST-PORT, 8000))), (USER-AGENT, "Bilibili Freedoooooom/MarkII")), REJECT-NO-DROP
# 备用域名
DOMAIN, api.biliapi.com, REJECT
DOMAIN, api.biliapi.net, REJECT
DOMAIN, app.biliapi.com, REJECT
DOMAIN, app.biliapi.net, REJECT
# 开屏广告
URL-REGEX, "^http:\/\/upos-sz-static\.bilivideo\.com\/ssaxcode\/\w{2}\/\w{2}\/\w{32}-1-SPLASH", REJECT-VIDEO-NO-DROP
URL-REGEX, "^http:\/\/[\d\.]+:8000\/v1\/resource\/\w{32}-1-SPLASH", REJECT-VIDEO-NO-DROP

[Rewrite]
# 播放页开通会员的横幅
^https:\/\/api\.bilibili\.com\/pgc\/activity\/deliver\/material\/receive\? mock-response-body data-type=text status-code=200 data="{"code":0,"data":{"closeType":"close_win","container":[],"showTime":""},"message":"success"}"
^https:\/\/api\.bilibili\.com\/pgc\/page\/channel\? response-body-json-jq '.data.modules |= map(select(.type != "TIP") | if .type == "BANNER" then .module_data.items |= map(select(.url | startswith("https://www.bilibili.com/blackboard/era/") | not)) else . end)'
^https:\/\/api\.bilibili\.com\/pgc\/view\/v2\/app\/season\? response-body-json-jq 'del(.data.payment)'

# 直播间
^https:\/\/api\.live\.bilibili\.com\/xlive\/(?:app-interface\/v2\/index\/feed|app-room\/v1\/index\/getInfoBy(?:Room|User))\? response-body-json-jq '.data |= (del(.play_together_info, .play_together_info_v2, .activity_banner_info) | if .function_card then .function_card[] = null end | if .new_tab_info.outer_list then .new_tab_info.outer_list |= map(select(.biz_id != 33)) end | if .card_list then .card_list |= map(select(.card_type | IN("banner_v2", "activity_card_v1") | not)) end | reduce ([["show_reserve_status"], false], [["reserve_info", "show_reserve_status"], false], [["shopping_info", "is_show"], 0]) as [$path, $value] (.; if getpath($path) then setpath($path; $value) end))'

# 开屏广告
^https:\/\/api\.bilibili\.com\/x\/mengqi\/v1\/resource reject-dict
^https:\/\/app\.bilibili\.com\/x\/resource\/peak\/download reject-dict
#^https:\/\/app\.bilibili\.com\/x\/v2\/splash\/list\? mock-response-body data-type=text status-code=200 data="OK"
#^https:\/\/app\.bilibili\.com\/x\/v2\/splash\/(show|event\/list2)\? response-body-json-jq '.data |= with_entries(if .key | IN("show", "event_list") then .value = [] else . end)'

# 屏蔽STUN
^https:\/\/api\.bilibili\.com\/x\/pd-proxy\/tracker\? response-body-json-jq '.data[][]?="stun.chat.bilibili.com:3478"'

# 满意度调研
^https:\/\/api\.bilibili\.com\/x\/v2\/dm\/qoe\/show\? reject-dict

# 大会员广告
^https:\/\/api\.bilibili\.com\/x\/vip\/ads\/materials\? reject-dict

# 直播广告
^https:\/\/api\.live\.bilibili\.com\/xlive\/e-commerce-interface\/v1\/ecommerce-user\/get_shopping_info\? reject-dict
^https:\/\/api\.live\.bilibili\.com\/xlive\/open-interface\/v2\/tracker\/conf\? response-body-json-jq '.data.domains=["wss://tracker.chat.bilibili.com"]'

# IP请求、地理位置请求
^https:\/\/api\.bilibili\.com\/x\/web-interface\/zone\?jsonp reject-dict
^https:\/\/app\.bilibili\.com\/x\/resource\/ip reject-dict

# 首页标签栏热更新
^https:\/\/app\.bilibili\.com\/x\/resource\/patch\/tab(\/v2)?\? reject-dict

# 移除皮肤推送
^https:\/\/app\.bilibili\.com\/x\/resource\/show\/skin\? response-body-json-del data.common_equip

# 移除右上角活动入口
^https:\/\/app\.bilibili\.com\/x\/resource\/top\/activity\? mock-response-body data-type=text status-code=200 data="{"code":-404,"message":"啥都木有","ttl":1,"data":null}"

# 搜索框填充词

# 请求头处理
^https:\/\/grpc\.biliapi\.net\/bilibili\.app\.(?:interface\.v1\.(?:Teenagers\/ModeStatus|Search\/DefaultWords)|view\.v1\.View\/TFInfo|viewunite\.v1\.View\/(?:PlayPause|ViewEndPage))$ response-header-add grpc-status 0

# 屏蔽默认搜索框关键词

# 青少年模式
^https:\/\/grpc\.biliapi\.net\/bilibili\.app\.interface\.v1\.Teenagers\/ModeStatus$ mock-response-body data-type=text data="AAAAABMKEQgCEgl0ZWVuYWdlcnMgAioA" mock-data-is-base64=true

# 视频暂停广告
^https:\/\/grpc\.biliapi\.net\/bilibili\.app\.(view\.v1\.View\/TFInfo|viewunite\.v1\.View\/(?:PlayPause|ViewEndPage))$ mock-response-body data-type=text data="AAAAAAA=" mock-data-is-base64=true

# 移除直播间链接跟踪参数
(^https:\/\/live\.bilibili\.com\/\d+)(?:\/?\?.*) 302 $1

# 移除直播间游戏推广
^https:\/\/line3-h5-mobile-api\.biligame\.com\/game\/live\/large_card_material\? reject-dict

# 移除视频链接跟踪参数
(^https:\/\/(?:www|m)\.bilibili\.com\/video\/(?:BV\w{10}|av\d{9}))(?:\/?\?.*) 302 $1

# 哔哩哔哩漫画 开屏 && 底栏广告
^https:\/\/manga\.bilibili\.com\/twirp\/comic\.v1\.Comic\/(?:Flash|ListFlash|GetActivityTab|GetBubbles) mock-response-body data-type=text data="{"code":0,"msg":"","data":null}"

# 哔哩哔哩漫画 广告
^https:\/\/manga\.bilibili\.com\/twirp\/comic\.v1\.(?:Comic\/AppInit|Home\/HomeFeed)\? response-body-json-jq '.data as $data | .data[("activity_tab", "flash", "operate") | select($data[.])]=null | if .data.feeds then .data.feeds |= map(select(.type | IN(15, 30) | not)) end'

[Script]
http-request ^https:\/\/(?:app\.bilibili\.com|grpc\.biliapi\.net)\/bilibili\.community\.service\.dm\.v1\.DM\/DmSegMobile$ script-path=https://rucu6.pages.dev/Scripts/bilibili/request.js, requires-body=true, binary-body-mode=true, tag=移除视频内插播广告, enable={sponsorBlock}
http-request ^https:\/\/(?:app\.bilibili\.com|grpc\.biliapi\.net)\/bilibili\.main\.community\.reply\.v1\.Reply\/MainList$ script-path=https://rucu6.pages.dev/Scripts/bilibili/request.js, requires-body=true, binary-body-mode=true, tag=移除评论区广告, argument=[{purifyComment}], enable={optimizeRequest}
http-response ^https:\/\/(?:app\.bilibili\.com|grpc\.biliapi\.net)\/bilibili\.app\.dynamic\.v2\.Dynamic\/DynAll$ script-path=https://rucu6.pages.dev/Scripts/bilibili/response.js, requires-body=true, binary-body-mode=true, tag=移除动态页面广告, argument=[{displayUpList}], enable={customizeDynamicPage}
http-response ^https:\/\/(?:app\.bilibili\.com|grpc\.biliapi\.net)\/bilibili\.app\.show\.v1\.Popular\/Index$ script-path=https://rucu6.pages.dev/Scripts/bilibili/response.js, requires-body=true, binary-body-mode=true, tag=过滤热搜热门话题, enable={filterHotSearch}
http-response ^https:\/\/app\.bilibili\.com\/x\/v2\/search\/square\? script-path=https://raw.githubusercontent.com/zwjtano/loon-/master/Scripts/bilibili/search-square.js, requires-body=false, tag=过滤搜索推荐, enable={filterSearchSuggest}
http-request ^https:\/\/(?:app\.bilibili\.com|grpc\.biliapi\.net)\/bilibili\.app\.interface\.v1\.Search\/DefaultWords$ script-path=https://raw.githubusercontent.com/zwjtano/loon-/master/Scripts/bilibili/default-search-word.js, requires-body=false, binary-body-mode=true, tag=屏蔽默认搜索框关键词, enable={filterDefaultSearchWord}
http-response ^https:\/\/(?:app\.bilibili\.com|grpc\.biliapi\.net)\/bilibili\.app\.playurl\.v1\.PlayURL\/PlayView$ script-path=https://rucu6.pages.dev/Scripts/bilibili/response.js, requires-body=true, binary-body-mode=true, tag=移除播放页面广告 playview
http-response ^https:\/\/(?:app\.bilibili\.com|grpc\.biliapi\.net)\/bilibili\.app\.playerunite\.v1\.Player\/PlayViewUnite$ script-path=https://rucu6.pages.dev/Scripts/bilibili/response.js, requires-body=true, binary-body-mode=true, tag=移除播放页面广告 playerunite
http-response ^https:\/\/(?:app\.bilibili\.com|grpc\.biliapi\.net)\/bilibili\.app\.view\.v1\.View\/(?:View|ViewProgress)$ script-path=https://rucu6.pages.dev/Scripts/bilibili/response.js, requires-body=true, binary-body-mode=true, tag=移除播放页面广告 view
http-response ^https:\/\/(?:app\.bilibili\.com|grpc\.biliapi\.net)\/bilibili\.app\.viewunite\.v1\.View\/(?:RelatesFeed|View|ViewProgress)$ script-path=https://rucu6.pages.dev/Scripts/bilibili/response.js, requires-body=true, binary-body-mode=true, tag=移除播放页面广告 viewunite
http-response ^https:\/\/(?:app\.bilibili\.com|grpc\.biliapi\.net)\/bilibili\.community\.service\.dm\.v1\.DM\/DmView$ script-path=https://rucu6.pages.dev/Scripts/bilibili/response.js, requires-body=true, binary-body-mode=true, tag=移除交互式弹幕
http-response ^https:\/\/(?:app\.bilibili\.com|grpc\.biliapi\.net)\/bilibili\.pgc\.gateway\.player\.v2\.PlayURL\/PlayView$ script-path=https://rucu6.pages.dev/Scripts/bilibili/response.js, requires-body=true, binary-body-mode=true, tag=移除播放器开通会员横幅
http-response ^https:\/\/(?:app\.bilibili\.com|grpc\.biliapi\.net)\/bilibili\.polymer\.app\.search\.v1\.Search\/SearchAll$ script-path=https://rucu6.pages.dev/Scripts/bilibili/response.js, requires-body=true, binary-body-mode=true, tag=移除搜索结果广告

# 以上为 Proto 处理, 以下为 JSON 处理

http-response ^https:\/\/api\.bilibili\.com\/pgc\/page\/(?:bangumi|cinema\/tab) script-path=https://rucu6.pages.dev/Scripts/bilibili/json.js, requires-body=true, tag=移除观影页广告, enable={customizePgcPage}
http-response ^https:\/\/app\.bilibili\.com\/x\/v2\/splash script-path=https://rucu6.pages.dev/Scripts/bilibili/json.js, requires-body=true, tag=移除开屏广告
http-response ^https:\/\/app\.bilibili\.com\/x\/resource\/show\/tab\/v2\? script-path=https://raw.githubusercontent.com/zwjtano/loon-/master/Scripts/bilibili/home-tabs.js, requires-body=true, tag=自定义首页顶部标签, argument=[{homeTopTabs},{customizeHomeTabs},{hideHomeTopGameCenter},{hideHomeBottomPublish},{hideHomeBottomMall}]
http-response ^https:\/\/app\.bilibili\.com\/x\/v2\/account\/mine script-path=https://raw.githubusercontent.com/zwjtano/loon-/master/Scripts/bilibili/mine.js, requires-body=true, tag=精简我的页面, enable={customizeMinePage}
http-response ^https:\/\/app\.bilibili\.com\/x\/v2\/feed\/index script-path=https://raw.githubusercontent.com/zwjtano/loon-/master/Scripts/bilibili/feed-index.js, requires-body=true, tag=过滤首页推荐流, argument=[{customizeHomeFeed},{filterVerticalVideo}]

[MITM]
hostname=*live.bilibili.com, *api.biligame.com, ap?.bilibili.com, grpc.biliapi.net, m.bilibili.com, manga.bilibili.com, www.bilibili.com
